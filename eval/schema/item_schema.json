{
  "$defs": {
    "CTTTargets": {
      "properties": {
        "p_value": {
          "default": [
            0.3,
            0.85
          ],
          "maxItems": 2,
          "minItems": 2,
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ],
          "title": "P Value",
          "type": "array"
        },
        "point_biserial_min": {
          "default": 0.2,
          "title": "Point Biserial Min",
          "type": "number"
        },
        "distractor_selection_min": {
          "default": 0.05,
          "title": "Distractor Selection Min",
          "type": "number"
        }
      },
      "title": "CTTTargets",
      "type": "object"
    },
    "ContentClassification": {
      "properties": {
        "domain": {
          "title": "Domain",
          "type": "string"
        },
        "subdomain": {
          "title": "Subdomain",
          "type": "string"
        },
        "competency_standard": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Competency Standard"
        },
        "content_tag_primary": {
          "title": "Content Tag Primary",
          "type": "string"
        },
        "content_tags_secondary": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Content Tags Secondary",
          "type": "array"
        }
      },
      "required": [
        "domain",
        "subdomain",
        "content_tag_primary"
      ],
      "title": "ContentClassification",
      "type": "object"
    },
    "IRTTargets": {
      "properties": {
        "b_difficulty": {
          "default": [
            -2.0,
            2.0
          ],
          "maxItems": 2,
          "minItems": 2,
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ],
          "title": "B Difficulty",
          "type": "array"
        },
        "a_discrimination_min": {
          "default": 0.5,
          "title": "A Discrimination Min",
          "type": "number"
        },
        "a_discrimination_ideal": {
          "default": [
            0.8,
            2.5
          ],
          "maxItems": 2,
          "minItems": 2,
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ],
          "title": "A Discrimination Ideal",
          "type": "array"
        },
        "c_guessing": {
          "default": 0.25,
          "title": "C Guessing",
          "type": "number"
        }
      },
      "title": "IRTTargets",
      "type": "object"
    },
    "ItemMetadata": {
      "properties": {
        "created_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created At"
        },
        "last_calibrated_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Calibrated At"
        },
        "content_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Hash"
        },
        "parent_item_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Item Id"
        },
        "enemy_item_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Enemy Item Ids",
          "type": "array"
        },
        "retirement_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retirement Reason"
        }
      },
      "title": "ItemMetadata",
      "type": "object"
    },
    "OptimizationLineage": {
      "properties": {
        "generation_method": {
          "default": "auto_generated",
          "enum": [
            "auto_generated",
            "human_authored",
            "hybrid"
          ],
          "title": "Generation Method",
          "type": "string"
        },
        "generator_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generator Model"
        },
        "generator_prompt_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generator Prompt Version"
        },
        "optimization_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Optimization Run Id"
        },
        "iteration": {
          "default": 0,
          "title": "Iteration",
          "type": "integer"
        },
        "change_type": {
          "default": "new",
          "title": "Change Type",
          "type": "string"
        },
        "change_justification": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Change Justification"
        }
      },
      "title": "OptimizationLineage",
      "type": "object"
    }
  },
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "item_code": {
      "title": "Item Code",
      "type": "string"
    },
    "version": {
      "default": 1,
      "title": "Version",
      "type": "integer"
    },
    "status": {
      "default": "draft",
      "enum": [
        "draft",
        "field_test",
        "operational",
        "retired",
        "flagged"
      ],
      "title": "Status",
      "type": "string"
    },
    "target_agent": {
      "title": "Target Agent",
      "type": "string"
    },
    "claim_id": {
      "title": "Claim Id",
      "type": "string"
    },
    "claim_text": {
      "title": "Claim Text",
      "type": "string"
    },
    "claim_type": {
      "enum": [
        "knowledge",
        "reasoning",
        "cross_domain",
        "edge_case"
      ],
      "title": "Claim Type",
      "type": "string"
    },
    "cognitive_level": {
      "enum": [
        "remember",
        "understand",
        "apply",
        "analyze",
        "evaluate",
        "create"
      ],
      "title": "Cognitive Level",
      "type": "string"
    },
    "depth_of_knowledge": {
      "maximum": 4,
      "minimum": 1,
      "title": "Depth Of Knowledge",
      "type": "integer"
    },
    "tier": {
      "enum": [
        "mcq",
        "scenario"
      ],
      "title": "Tier",
      "type": "string"
    },
    "source_citation": {
      "title": "Source Citation",
      "type": "string"
    },
    "source_url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Url"
    },
    "content_classification": {
      "anyOf": [
        {
          "$ref": "#/$defs/ContentClassification"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "ctt_targets": {
      "$ref": "#/$defs/CTTTargets"
    },
    "irt_targets": {
      "$ref": "#/$defs/IRTTargets"
    },
    "item_metadata": {
      "$ref": "#/$defs/ItemMetadata"
    },
    "optimization_lineage": {
      "$ref": "#/$defs/OptimizationLineage"
    },
    "calibration_history": {
      "default": [],
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Calibration History",
      "type": "array"
    },
    "version_history": {
      "default": [],
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Version History",
      "type": "array"
    }
  },
  "required": [
    "item_code",
    "target_agent",
    "claim_id",
    "claim_text",
    "claim_type",
    "cognitive_level",
    "depth_of_knowledge",
    "tier",
    "source_citation"
  ],
  "title": "ExamItem",
  "type": "object"
}